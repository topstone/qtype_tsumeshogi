<quiz>

  <!-- ============================================================
       問題1: 一手詰 (馬による詰み)
       局面: 後手玉が1九、先手は馬が2八と金が持ち駒
       正解: G*1八 → 詰み
       ============================================================ -->
  <question type="tsumeshogi">
    <name>
      <text>詰将棋 001 — 一手詰（馬打ち）</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p>次の一手で詰みを実現してください。</p>]]></text>
    </questiontext>
    <generalfeedback format="html">
      <text><![CDATA[<p>馬を打って詰みです。</p>]]></text>
    </generalfeedback>
    <defaultgrade>1</defaultgrade>
    <penalty>0</penalty>
    <hidden>0</hidden>
    <sfen>8k/9/8K/9/9/9/9/9/9 b B 1</sfen>
    <correctanswer>B*8b</correctanswer>
  </question>

  <!-- ============================================================
